# Copy to config.env and edit:
#   cp config.env.example config.env
#   chmod 600 config.env

# Web UI Basic Auth
AUTH_USER=admin
AUTH_PASS=change-me

# Listen address (keep loopback if you put a reverse proxy in front)
BIND=127.0.0.1
PORT=7681

# Default working directory for Claude Code (use an absolute path you own)
# Examples: /home/YOUR_USER/projects  or  /var/lib/claude-phone/workspace
WORK_DIR=

# Permission mode for new chats:
# acceptEdits | plan | default | dontAsk | auto | bypassPermissions
DEFAULT_PERMISSION_MODE=acceptEdits

# Max duration per turn (ms)
TURN_TIMEOUT_MS=600000

# Max concurrent Claude CLI processes (use 1 on small VPS)
MAX_CONCURRENT_TURNS=1

# 1 = background jobs by default (survive tab close)
# 0 = foreground by default (disconnect aborts after ~4s)
DEFAULT_BACKGROUND=1

# Public URL / hostname (optional; used by Caddy helper scripts)
PUBLIC_URL=https://claude.example.com
PUBLIC_HOST=claude.example.com

# Claude Code binary
CLAUDE_BIN=claude
